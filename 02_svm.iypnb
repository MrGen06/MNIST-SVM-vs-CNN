{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"gpuType":"T4"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"},"accelerator":"GPU"},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"EVXr4sEjT5pU","executionInfo":{"status":"ok","timestamp":1778686199234,"user_tz":-330,"elapsed":8076,"user":{"displayName":"GOUTAM KHANDELWAL","userId":"15586415226154958668"}},"outputId":"56eb88ab-5420-4e6c-ce02-dc5c5526b72e"},"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","Drive successfully mounted and project directories are ready!\n"]}],"source":["from google.colab import drive\n","import os\n","\n","# 1. Mount the Google Drive\n","drive.mount('/content/drive')\n","\n","# 2. Define the exact path to the shared project folder\n","PROJECT_ROOT = '/content/drive/MyDrive/MNIST-Project/'\n","\n","# 3. Automatically create the required sub-folders if they don't exist yet\n","os.makedirs(os.path.join(PROJECT_ROOT, 'data'), exist_ok=True)\n","os.makedirs(os.path.join(PROJECT_ROOT, 'models'), exist_ok=True)\n","os.makedirs(os.path.join(PROJECT_ROOT, 'results'), exist_ok=True)\n","\n","print(\"Drive successfully mounted and project directories are ready!\")"]},{"cell_type":"code","source":["import os\n","import time\n","import numpy as np\n","from sklearn.svm import SVC\n","from sklearn.metrics import accuracy_score\n","\n","print(\"Loading flattened data for SVM baselines...\")\n","data_dir = os.path.join(PROJECT_ROOT, 'data')\n","\n","# Load Training Splits\n","x_train_5k = np.load(os.path.join(data_dir, 'x_train_5k_flat.npy'))\n","y_train_5k = np.load(os.path.join(data_dir, 'y_train_5k.npy'))\n","\n","x_train_15k = np.load(os.path.join(data_dir, 'x_train_15k_flat.npy'))\n","y_train_15k = np.load(os.path.join(data_dir, 'y_train_15k.npy'))\n","\n","# Load Testing Data\n","x_test = np.load(os.path.join(data_dir, 'x_test_flat.npy'))\n","y_test = np.load(os.path.join(data_dir, 'y_test.npy'))\n","\n","print(\"Data loaded successfully!\")"],"metadata":{"id":"CQEb5hwYYuhY","colab":{"base_uri":"https://localhost:8080/","height":236},"executionInfo":{"status":"error","timestamp":1778693573698,"user_tz":-330,"elapsed":1595,"user":{"displayName":"NAMAN KUMAR","userId":"03777463724255967228"}},"outputId":"36e6605d-bfa9-4bff-ad3c-d208287d73e6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading flattened data for SVM baselines...\n"]},{"output_type":"error","ename":"NameError","evalue":"name 'PROJECT_ROOT' is not defined","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mNameError\u001b[0m                                 Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_9751/720168114.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m      6\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m      7\u001b[0m \u001b[0mprint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m\"Loading flattened data for SVM baselines...\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m----> 8\u001b[0;31m \u001b[0mdata_dir\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mos\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mpath\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mjoin\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mPROJECT_ROOT\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m'data'\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m      9\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     10\u001b[0m \u001b[0;31m# Load Training Splits\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mNameError\u001b[0m: name 'PROJECT_ROOT' is not defined"]}]},{"cell_type":"code","source":["print(\"--- Training Baseline Linear SVM (5,000 Images) ---\")\n","svm_5k = SVC(kernel='linear')\n","\n","start_time = time.time()\n","svm_5k.fit(x_train_5k, y_train_5k)\n","time_5k = time.time() - start_time\n","\n","print(f\"Training Time (5k): {time_5k:.2f} seconds\")\n","\n","# Evaluate Accuracy\n","preds_5k = svm_5k.predict(x_test)\n","acc_5k = accuracy_score(y_test, preds_5k)\n","print(f\"Test Accuracy (5k): {acc_5k * 100:.2f}%\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XEl_00GGLQeX","executionInfo":{"status":"ok","timestamp":1778673242796,"user_tz":-330,"elapsed":12589,"user":{"displayName":"GOUTAM KHANDELWAL","userId":"15586415226154958668"}},"outputId":"218eeab3-6356-41df-c9b8-791478f2148b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Training Baseline Linear SVM (5,000 Images) ---\n","Training Time (5k): 5.30 seconds\n","Test Accuracy (5k): 91.01%\n"]}]},{"cell_type":"code","source":["print(\"--- Training Baseline Linear SVM (15,000 Images) ---\")\n","svm_15k = SVC(kernel='linear')\n","\n","start_time = time.time()\n","svm_15k.fit(x_train_15k, y_train_15k)\n","time_15k = time.time() - start_time\n","\n","print(f\"Training Time (15k): {time_15k:.2f} seconds\")\n","\n","# Evaluate Accuracy\n","preds_15k = svm_15k.predict(x_test)\n","acc_15k = accuracy_score(y_test, preds_15k)\n","print(f\"Test Accuracy (15k): {acc_15k * 100:.2f}%\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Gsmw3_dtL6Cx","executionInfo":{"status":"ok","timestamp":1778673306287,"user_tz":-330,"elapsed":24679,"user":{"displayName":"GOUTAM KHANDELWAL","userId":"15586415226154958668"}},"outputId":"96c12735-eefd-4ec5-c4f0-0171cf1e43c9"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Training Baseline Linear SVM (15,000 Images) ---\n","Training Time (15k): 13.55 seconds\n","Test Accuracy (15k): 92.19%\n"]}]},{"cell_type":"code","source":["import os\n","import time\n","import numpy as np\n","from sklearn.svm import SVC\n","from sklearn.metrics import accuracy_score\n","from sklearn.metrics.pairwise import polynomial_kernel, rbf_kernel\n","\n","data_dir = os.path.join(PROJECT_ROOT, 'data')\n","\n","# Load the PCA-compressed Full Dataset\n","print(\"Loading PCA-compressed data for Advanced SVM...\")\n","x_train_pca = np.load(os.path.join(data_dir, 'x_train_pca.npy'))\n","y_train_full = np.load(os.path.join(data_dir, 'y_train_full.npy'))\n","\n","x_test_pca = np.load(os.path.join(data_dir, 'x_test_pca.npy'))\n","y_test = np.load(os.path.join(data_dir, 'y_test.npy'))\n","\n","print(f\"Data loaded! Training shape is now perfectly compressed: {x_train_pca.shape}\")"],"metadata":{"id":"lorHqhRJMGlu","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778686283331,"user_tz":-330,"elapsed":204,"user":{"displayName":"GOUTAM KHANDELWAL","userId":"15586415226154958668"}},"outputId":"ee3dbefe-ee59-42d1-96f5-40fa3f5441f7"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading PCA-compressed data for Advanced SVM...\n","Data loaded! Training shape is now perfectly compressed: (60000, 59)\n"]}]},{"cell_type":"code","source":["def hybrid_kernel(X, Y):\n","    \"\"\"\n","    Custom Kernel: 70% Polynomial (Global structure) + 30% RBF (Local details)\n","    \"\"\"\n","    # 1. Calculate the standard Polynomial Kernel (degree=3 is standard for images)\n","    poly_matrix = polynomial_kernel(X, Y, degree=3, gamma=1.0, coef0=1.0)\n","\n","    # 2. Calculate the standard RBF Kernel\n","    rbf_matrix = rbf_kernel(X, Y, gamma=0.01)\n","\n","    # 3. Blend them!\n","    hybrid_matrix = (0.7 * poly_matrix) + (0.3 * rbf_matrix)\n","\n","    return hybrid_matrix\n","\n","print(\"Custom Hybrid Kernel successfully defined in memory!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4liLIsoT5ve4","executionInfo":{"status":"ok","timestamp":1778686290020,"user_tz":-330,"elapsed":9,"user":{"displayName":"GOUTAM KHANDELWAL","userId":"15586415226154958668"}},"outputId":"c37609fe-b628-4537-90d9-29994fc0bcf0"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Custom Hybrid Kernel successfully defined in memory!\n"]}]},{"cell_type":"code","source":["import time\n","from sklearn.svm import SVC\n","from sklearn.metrics import accuracy_score\n","\n","print(\"--- Commencing Ablation Study on 15k PCA Subset ---\")\n","\n","# Slice the perfectly shuffled data down to 15,000 to save RAM\n","x_train_15k_pca = x_train_pca[:15000]\n","y_train_15k = y_train_full[:15000]\n","\n","# Model A: Linear\n","print(\"1. Training Linear SVM + PCA...\")\n","start = time.time()\n","svm_linear = SVC(kernel='linear')\n","svm_linear.fit(x_train_15k_pca, y_train_15k)\n","acc_linear = accuracy_score(y_test, svm_linear.predict(x_test_pca))\n","print(f\"Linear + PCA Accuracy: {acc_linear * 100:.2f}% (Time: {time.time()-start:.1f}s)\")\n","\n","# Model B: Standard Polynomial\n","print(\"\\n2. Training Standard Polynomial SVM + PCA...\")\n","start = time.time()\n","svm_poly = SVC(kernel='poly', degree=3)\n","svm_poly.fit(x_train_15k_pca, y_train_15k)\n","acc_poly = accuracy_score(y_test, svm_poly.predict(x_test_pca))\n","print(f\"Polynomial + PCA Accuracy: {acc_poly * 100:.2f}% (Time: {time.time()-start:.1f}s)\")\n","\n","# Model C: Your Custom Hybrid!\n","print(\"\\n3. Training Custom Hybrid Kernel SVM + PCA...\")\n","start = time.time()\n","svm_hybrid = SVC(kernel=hybrid_kernel)\n","svm_hybrid.fit(x_train_15k_pca, y_train_15k)\n","acc_hybrid = accuracy_score(y_test, svm_hybrid.predict(x_test_pca))\n","print(f\"Hybrid + PCA Accuracy: {acc_hybrid * 100:.2f}% (Time: {time.time()-start:.1f}s)\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ABD6DYE46sfw","executionInfo":{"status":"ok","timestamp":1778686344765,"user_tz":-330,"elapsed":49728,"user":{"displayName":"GOUTAM KHANDELWAL","userId":"15586415226154958668"}},"outputId":"6b70929c-e8cb-48ad-f407-3a3ab4a49620"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Commencing Ablation Study on 15k PCA Subset ---\n","1. Training Linear SVM + PCA...\n","Linear + PCA Accuracy: 93.11% (Time: 4.8s)\n","\n","2. Training Standard Polynomial SVM + PCA...\n","Polynomial + PCA Accuracy: 97.23% (Time: 9.0s)\n","\n","3. Training Custom Hybrid Kernel SVM + PCA...\n","Hybrid + PCA Accuracy: 97.68% (Time: 36.0s)\n"]}]},{"cell_type":"code","source":["import joblib\n","\n","models_dir = os.path.join(PROJECT_ROOT, 'models')\n","os.makedirs(models_dir, exist_ok=True)\n","\n","# Save Hybrid SVM model\n","svm_model_path = os.path.join(models_dir, 'hybrid_svm_15k.pkl')\n","joblib.dump(svm_hybrid, svm_model_path)\n","\n","print(f\"Hybrid SVM successfully saved to: {svm_model_path}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jOaDiLn964XJ","executionInfo":{"status":"ok","timestamp":1778687484001,"user_tz":-330,"elapsed":28,"user":{"displayName":"GOUTAM KHANDELWAL","userId":"15586415226154958668"}},"outputId":"4867d24f-e1ab-4f5d-b0dc-723a5ff40b1f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Hybrid SVM successfully saved to: /content/drive/MyDrive/MNIST-Project/models/hybrid_svm_15k.pkl\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"SjTfZorQCR9v"},"execution_count":null,"outputs":[]}]}